#!/bin/bash

# Проверка прав root
if [[ $EUID -ne 0 ]]; then
   echo "Этот скрипт должен быть запущен от имени root."
   exit 1
fi

echo "=================================================="
echo "       Настройка GRE-туннеля (HQ-RTR / BR-RTR)    "
echo "=================================================="
echo ""

# Выбор маршрутизатора
echo "Выберите настраиваемый маршрутизатор:"
echo "1) HQ-RTR (Локальный: 172.16.4.2, Туннель: 10.0.0.1)"
echo "2) BR-RTR (Локальный: 172.16.5.2, Туннель: 10.0.0.2)"
read -p "Введите номер варианта (1 или 2): " choice

# Инициализация переменных
IFACE_DIR="/etc/net/ifaces/gre0"

case $choice in
    1)
        LOCAL_IP="172.16.4.2"
        REMOTE_IP="172.16.5.2"
        TUNNEL_IP="10.0.0.1/30"
        HOSTNAME="HQ-RTR"
        PING_TARGET="10.0.0.2"
        ;;
    2)
        LOCAL_IP="172.16.5.2"
        REMOTE_IP="172.16.4.2"
        TUNNEL_IP="10.0.0.2/30"
        HOSTNAME="BR-RTR"
        PING_TARGET="10.0.0.1"
        ;;
    *)
        echo "Неверный выбор. Выход."
        exit 1
        ;;
esac

echo ""
echo "--- Настройка $HOSTNAME ---"
echo "Локальный внешний IP: $LOCAL_IP"
echo "Удаленный внешний IP: $REMOTE_IP"
echo "Адрес туннеля: $TUNNEL_IP"
echo ""

# 1. Загрузка модуля
echo "[Шаг 1] Загрузка модуля GRE..."
modprobe gre
if ! grep -q "^gre" /etc/modules; then
    echo "gre" >> /etc/modules
    echo "Модуль gre добавлен в /etc/modules."
else
    echo "Модуль gre уже есть в /etc/modules."
fi

# 2. Создание директории интерфейса
echo "[Шаг 2] Создание конфигурации интерфейса..."
mkdir -p "$IFACE_DIR"

# 3. Запись файла options
echo "Запись $IFACE_DIR/options ..."
cat > "$IFACE_DIR/options" <<EOF
TYPE=gre
BOOTPROTO=static
REMOTEADDR=$REMOTE_IP
LOCALADDR=$LOCAL_IP
TTL=64
EOF

# 4. Запись файла ipv4address
echo "Запись $IFACE_DIR/ipv4address ..."
echo "$TUNNEL_IP" > "$IFACE_DIR/ipv4address"

# 5. Применение настроек
echo ""
echo "[Шаг 3] Перезапуск сети..."
echo "Выполняется: systemctl restart network"
systemctl restart network

# 6. Проверка
echo ""
echo "[Шаг 4] Проверка состояния интерфейса..."
ip a show gre0

echo ""
read -p "Выполнить пинг туннельного адреса соседа ($PING_TARGET)? (y/n): " ping_ask
if [[ "$ping_ask" =~ ^[Yy]$ ]]; then
    echo "Пингуем $PING_TARGET..."
    ping -c 4 $PING_TARGET
fi

echo ""
echo "Настройка завершена."
